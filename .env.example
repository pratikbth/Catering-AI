REACT_APP_BACKEND_URL=http://localhost:8000

# Server-side only. Do not put this in React code.
GEMINI_API_KEY=your_google_ai_studio_api_key_here

# Nano Banana model options:
# gemini-3.1-flash-image-preview  Fast, strong default
# gemini-3-pro-image-preview      Higher quality for complex prompts
# gemini-2.5-flash-image          Older low-latency Nano Banana model
NANO_BANANA_MODEL=gemini-3.1-flash-image-preview

# Set to false if you want missing/failed API credentials to fail instead of using local placeholder images.
ALLOW_LOCAL_IMAGE_FALLBACK=true
